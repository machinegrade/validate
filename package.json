{
  "name": "@machinegrade/validate",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable demand-test sandbox: Hono service with pluggable validators (json_schema, openapi_response, sql), API keys, metering, telemetry funnel, and an MCP adapter.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "mcp": "tsx mcp/server.ts"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "hono": "^4.6.14",
    "node-sql-parser": "^5.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
